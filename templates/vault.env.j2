# Managed by Ansible — do not edit manually.
# Changes to this file will be overwritten on the next playbook run.
# This file is sourced by systemd as an EnvironmentFile for vault.service.
# It must always exist (a missing EnvironmentFile causes a hard unit failure).

{% if vault_enable_file_permissions_check | bool %}
VAULT_ENABLE_FILE_PERMISSIONS_CHECK=true
{% endif %}
{% if vault_seal_type == 'transit' and vault_seal_transit_token %}
VAULT_TOKEN={{ vault_seal_transit_token }}
{% endif %}
{% if vault_seal_type == 'awskms' %}
{% if vault_seal_awskms_access_key %}
AWS_ACCESS_KEY_ID={{ vault_seal_awskms_access_key }}
{% endif %}
{% if vault_seal_awskms_secret_key %}
AWS_SECRET_ACCESS_KEY={{ vault_seal_awskms_secret_key }}
{% endif %}
{% endif %}
{% if vault_seal_type == 'azurekeyvault' and vault_seal_azurekeyvault_client_secret %}
AZURE_CLIENT_SECRET={{ vault_seal_azurekeyvault_client_secret }}
{% endif %}
{% if vault_seal_type == 'gcpckms' and vault_seal_gcpckms_credentials %}
GOOGLE_APPLICATION_CREDENTIALS={{ vault_seal_gcpckms_credentials }}
{% endif %}
